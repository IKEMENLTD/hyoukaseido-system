LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# OAuth連携（個人DM通知用）
CHATWORK_CLIENT_ID=your-chatwork-client-id
CHATWORK_CLIENT_SECRET=your-chatwork-client-secret
OAUTH_TOKEN_ENCRYPTION_KEY=your-64-char-hex-string-for-aes-256-gcm
OAUTH_STATE_SECRET=your-random-secret-for-oauth-state-hmac
CRON_SECRET=your-random-secret-for-cron-auth
